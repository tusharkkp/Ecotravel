# Server port
PORT=5000

# MongoDB connection string (replace with your MongoDB Atlas URI for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/eco-travel-planner?retryWrites=true&w=majority

# JWT Secret for authentication tokens
JWT_SECRET=your_secure_jwt_secret_key_at_least_32_characters_long

# Environment
NODE_ENV=production

# Frontend URL for CORS (replace with your deployed frontend URL)
FRONTEND_URL=https://your-frontend-url.com 